pipeline {
    agent any

        tools {
        jdk 'JDK17'
        maven 'Maven'
    }

    environment {
        JAVA_HOME = tool 'JDK17'
        PATH = "${JAVA_HOME}\\bin;${env.PATH}"
    }

    stages {

        stage('Check Java') {
            steps {
                bat 'java -version'
            }
        }

    stages {

        stage('Build + Test') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t cicd-app .'
            }
        }

        stage('Deploy') {
            steps {
                bat 'docker stop cicd-container || exit 0'
                bat 'docker rm cicd-container || exit 0'
                bat 'docker run -d -p 9090:8080 --name cicd-container cicd-app'
            }
        }
    }
}